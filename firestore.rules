rules_version = '2';

// ============================================================================
//  Baumbewaesserung – Mehrmandanten-/Rollen-Regeln  (AKTIV/deployt)
//  Deploy: firebase deploy --only firestore:rules
//  Voraussetzung (erfuellt): Firebase Auth aktiv + orgId auf allen Dokumenten.
//
//  Claims:  request.auth.token.{ orgId, role, cap }
//    - role: Rollen-Key (für UI/Module), frei definierbar
//    - cap : Basis-Typ -> Datenrechte: admin | editor | readonly | driver
//  Daten tragen orgId (denormalisiert) -> Rules ohne get() auf das Parent.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role()     { return signedIn() ? request.auth.token.role : ''; }
    function cap()      { return signedIn() ? request.auth.token.cap  : ''; }
    function myOrg()    { return signedIn() ? request.auth.token.orgId : ''; }
    function isSuper()  { return signedIn() && role() == 'superadmin'; }
    function inOrg(oid) { return signedIn() && (myOrg() == oid || isSuper()); }

    // Datenrechte ueber den Basis-Typ (cap), Superadmin immer
    function canManage(oid) { return isSuper() || (inOrg(oid) && cap() == 'admin'); }
    function canPlan(oid)   { return isSuper() || (inOrg(oid) && (cap() == 'admin' || cap() == 'editor')); }

    // Fahrer (cap 'driver') duerfen an Baeumen NUR diese Felder aendern:
    function onlyStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['lastStatus','lastReason','lastNote','lastDriver','lastReportAt','history','datum','zustand']);
    }
    // Fahrer duerfen an Touren NUR den Abschluss-/Wiederaufnahme-Status setzen:
    function onlyTourStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status','closedAt','closedBy','lastClosedDate','reopenedAt','reopenedBy']);
    }
    function orgUnchanged() { return request.resource.data.orgId == resource.data.orgId; }

    // ----- Globale Rollen-Definitionen -----
    match /roles/{rid} {
      allow read:  if signedIn();   // jeder Eingeloggte liest die Modul-Config
      allow write: if isSuper();
    }

    // ----- Mandanten -----
    match /orgs/{oid} {
      allow read:  if inOrg(oid);
      allow write: if isSuper();
    }

    // ----- Nutzungs-Zähler je Mandant (Reads/Writes/Deletes, App-seitig hochgezählt) -----
    match /usage/{uid} {
      allow read:          if isSuper() || (inOrg(resource.data.orgId) && cap() == 'admin');
      allow create, update: if signedIn() && inOrg(request.resource.data.orgId); // jeder eingeloggte Nutzer zählt seine Org hoch
      allow delete:        if isSuper();
    }

    // ----- Nutzerprofile (Admin-UI; massgeblich sind die Claims) -----
    match /users/{uid} {
      allow read:   if signedIn() && (request.auth.uid == uid || inOrg(resource.data.orgId));
      allow create: if canManage(request.resource.data.orgId);
      allow update: if canManage(resource.data.orgId);
      allow delete: if canManage(resource.data.orgId);
    }

    // ----- Fahrer (Name + PIN-Hash) — PIN-Pruefung serverseitig -----
    match /drivers/{did} {
      allow read:   if canManage(resource.data.orgId);
      allow create: if canManage(request.resource.data.orgId);
      allow update, delete: if canManage(resource.data.orgId);
    }

    // ----- Projekte + Unterkollektionen -----
    match /projects/{pid} {
      // Org des Parent-Projekts (fuer Lesen unbeschr. Unterkollektions-Queries)
      function projOrg() { return get(/databases/$(database)/documents/projects/$(pid)).data.orgId; }
      function canReadProj() { return inOrg(projOrg()); }

      allow read:   if inOrg(resource.data.orgId);
      allow create: if canPlan(request.resource.data.orgId);
      allow update: if canPlan(resource.data.orgId) && orgUnchanged();
      allow delete: if canPlan(resource.data.orgId);

      match /trees/{tid} {
        allow read:   if canReadProj();
        allow create: if canPlan(request.resource.data.orgId);
        allow delete: if canPlan(resource.data.orgId);
        allow update: if (canPlan(resource.data.orgId) && orgUnchanged())
                      || (cap() == 'driver' && inOrg(resource.data.orgId) && orgUnchanged() && onlyStatusFields());
      }
      match /tours/{tid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId);
        allow update:         if (canPlan(resource.data.orgId) && orgUnchanged())
                              || (cap() == 'driver' && inOrg(resource.data.orgId) && orgUnchanged() && onlyTourStatusFields());
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /routes/{tid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId);
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /reasons/{rid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId);
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /arten/{aid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId);
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /tourHistory/{hid} {
        allow read:   if canReadProj();
        allow create: if inOrg(request.resource.data.orgId) && (cap() == 'driver' || canPlan(request.resource.data.orgId));
        allow update, delete: if canPlan(resource.data.orgId);
      }
    }
  }
}
