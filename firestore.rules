rules_version = '2';

// ============================================================================
//  Baumbewaesserung – Mehrmandanten-/Rollen-Regeln  (AKTIV/deployt)
//  Deploy: firebase deploy --only firestore:rules
//  Voraussetzung (erfuellt): Firebase Auth aktiv + orgId auf allen Dokumenten.
//
//  Claims:  request.auth.token.{ orgId, role, cap }
//    - role: Rollen-Key (für UI/Module), frei definierbar
//    - cap : Basis-Typ -> Datenrechte: admin | editor | readonly | driver
//  Daten tragen orgId (denormalisiert) -> Rules ohne get() auf das Parent.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role()     { return signedIn() ? request.auth.token.role : ''; }
    function cap()      { return signedIn() ? request.auth.token.cap  : ''; }
    function myOrg()    { return signedIn() ? request.auth.token.orgId : ''; }
    function isSuper()  { return signedIn() && role() == 'superadmin'; }
    function inOrg(oid) { return signedIn() && (myOrg() == oid || isSuper()); }

    // Datenrechte ueber den Basis-Typ (cap), Superadmin immer
    function canManage(oid) { return isSuper() || (inOrg(oid) && cap() == 'admin'); }
    function canPlan(oid)   { return isSuper() || (inOrg(oid) && (cap() == 'admin' || cap() == 'editor')); }

    // Fahrer (cap 'driver') duerfen an Baeumen NUR diese Felder aendern:
    function onlyStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['lastStatus','lastReason','lastNote','lastDriver','lastReportAt','history','datum','zustand','lastFuellgrad']);
    }
    // Fahrer duerfen an Touren NUR den Abschluss-/Wiederaufnahme-Status setzen:
    function onlyTourStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status','closedAt','closedBy','lastClosedDate','reopenedAt','reopenedBy']);
    }
    function orgUnchanged() { return request.resource.data.orgId == resource.data.orgId; }

    // Fahrer duerfen an einer Postfach-Empfangsquittung NUR diese Felder setzen:
    function onlyMessageStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['deliveredAt','seenAt','doneAt']);
    }

    // ----- Globale Rollen-Definitionen -----
    match /roles/{rid} {
      allow read:  if signedIn();   // jeder Eingeloggte liest die Modul-Config
      allow write: if isSuper();
    }

    // ----- Globale Konfiguration (z. B. Lizenz-Preisliste) — nur Superadmin -----
    match /config/{cid} {
      allow read, write: if isSuper();
    }

    // ----- Globale App-Einstellungen (z. B. Präsenz-Erfassung an/aus) -----
    // Alle eingeloggten Apps müssen das Flag lesen können (steuert das Loggen); schreiben nur Superadmin.
    match /appsettings/{id} {
      allow read: if signedIn();
      allow write: if isSuper();
    }

    // ----- Präsenz/Sitzungserfassung (Superadmin-Auswertung) -----
    // Jede eingeloggte App legt ihre eigene Sitzung an und aktualisiert Heartbeat/Logout;
    // lesen/aufräumen nur Superadmin. Enthält nur Präsenzdaten (kein fachlicher Inhalt).
    match /presence/{sid} {
      allow read, delete: if isSuper();
      // Owner-Bindung: nur die eigene Sitzung (uid == Auth-UID) anlegen/aktualisieren; Update nur Heartbeat/Logout.
      // Lesen bleibt Superadmin-only → eine fremde Sitzungs-ID ist ohnehin nicht auffindbar (kein gezieltes Manipulieren).
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['orgId','kind','userKey','name','role','app','buildId','loginAt','lastSeen','logoutAt','uid']);
      allow update: if signedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen','logoutAt']);
    }

    // ----- Mandanten -----
    match /orgs/{oid} {
      allow read:  if inOrg(oid);
      // Stadt-Admins duerfen NUR Abwesenheits-Typen + Fahrzeug-Arten am Org-Doc pflegen (Einsatzplaner);
      // alle uebrigen Org-Felder (code, orsKey, dispoResources, ...) bleiben Superadmin/Functions.
      allow update: if isSuper() || (inOrg(oid) && cap() == 'admin'
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['absenceTypes','vehicleTypes']));
      allow create, delete: if isSuper();

      // Rollen-/Modul-Definitionen je Mandant (Stadt-Admin pflegt eigene Rollen)
      match /roles/{rid} {
        allow read:  if inOrg(oid);
        allow write: if isSuper() || (inOrg(oid) && cap() == 'admin');
      }
    }

    // ----- Nutzungs-Zähler je Mandant (Reads/Writes/Deletes, App-seitig hochgezählt) -----
    match /usage/{uid} {
      allow read:          if isSuper() || (inOrg(resource.data.orgId) && cap() == 'admin');
      allow create, update: if signedIn() && cap() != 'driver' && inOrg(request.resource.data.orgId)
                            && request.resource.data.keys().hasOnly(['orgId','monat','reads','writes','deletes','updatedAt']); // nur erwartete Zählfelder; Fahrer-App schreibt nie usage
      allow delete:        if isSuper();
    }

    // ----- Fehler-Protokoll (globaler Fehler-Handler) — best-effort, nur Admin liest -----
    match /errors/{eid} {
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid   // nur die eigene uid (keine Fremd-Impersonation)
                    && request.resource.data.keys().hasOnly(['app','kind','message','stack','url','ua','uid','at']);
      allow read:   if isSuper() || cap() == 'admin';
      allow update: if false;                            // unveränderlich
      allow delete: if isSuper();
    }

    // ----- Nutzerprofile (Admin-UI; massgeblich sind die Claims) -----
    match /users/{uid} {
      allow read:   if signedIn() && (request.auth.uid == uid || inOrg(resource.data.orgId));
      allow create: if canManage(request.resource.data.orgId);
      allow update: if canManage(resource.data.orgId);
      allow delete: if canManage(resource.data.orgId);
    }

    // ----- Fahrer (Name + PIN-Hash) — PIN-Pruefung serverseitig -----
    match /drivers/{did} {
      // "Person ohne Login": kein PIN-Hash, keine Rolle, noLogin==true → kostet keine Lizenz, gewaehrt keinen Zugang.
      function isLoginless(d) {
        return d.noLogin == true
            && !('pinHash' in d) && !('pinSalt' in d)
            && (!('role' in d) || d.role == '');
      }
      allow read:   if canPlan(resource.data.orgId);   // Planer dürfen Namen lesen (Einsatzplaner/Tour-Besetzung); Hash ist scrypt
      // Admin: alles AUSSER role='superadmin' setzen (Eskalation — Superadmin wird NUR über Claims/setUserRole vergeben,
      // driverLogin liest role aus diesem Doc). Planer/Einsatzleiter: NUR Login-lose Personen anlegen (nie PIN/Rolle).
      allow create: if isSuper()
                    || (inOrg(request.resource.data.orgId) && cap() == 'admin'
                        && (!('role' in request.resource.data) || request.resource.data.role != 'superadmin'))
                    || (canPlan(request.resource.data.orgId) && isLoginless(request.resource.data));
      // Admin: alles, ABER orgId bleibt fest (kein Mandanten-Umzug per Roh-Write, sonst Cross-Tenant-Takeover)
      // und role wird nicht auf superadmin gehoben. Planer: (a) Abwesenheiten an JEDER Person,
      // ODER (b) Pflegefelder NUR an Login-losen Personen (Anmeldedaten/Rolle/noLogin unberührt).
      allow update: if isSuper()
                    || (inOrg(resource.data.orgId) && cap() == 'admin' && orgUnchanged()
                        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                            || request.resource.data.role != 'superadmin'))
                    || (canPlan(resource.data.orgId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['absences']))
                    || (canPlan(resource.data.orgId) && resource.data.noLogin == true
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['name','nameLower','funktion','betriebshof','persnr','einsatz','loginRequested','active','absences','notiz']));
      // Admin: alles. Planer: nur Login-lose Personen loeschen.
      allow delete: if canManage(resource.data.orgId)
                    || (canPlan(resource.data.orgId) && resource.data.noLogin == true
                        && !('pinHash' in resource.data) && !('pinSalt' in resource.data));

      // FCM-Geräte-Token: Fahrer schreibt/liest NUR die eigenen (Owner ueber Auth-UID 'drv_'+did).
      // Die Cloud Function liest sie per Admin-SDK (umgeht Rules).
      match /tokens/{tid} {
        allow read, write: if request.auth.uid == 'drv_' + did;
      }
    }

    // ----- Verfügbarkeit Personal & Fahrzeuge je Mandant/Tag (Einsatzplaner) -----
    match /availability/{aid} {
      allow read:           if inOrg(resource.data.orgId);
      allow create:         if canPlan(request.resource.data.orgId);
      allow update, delete: if canPlan(resource.data.orgId);
    }

    // ----- Push-/Postfach-Nachrichten (mandantenrein; Fahrer sehen/erledigen NUR ihr eigenes) -----
    match /messages/{msgId} {
      allow read:           if canPlan(resource.data.orgId);            // Desktop: Planer/Admin der Org
      allow create:         if canPlan(request.resource.data.orgId);    // inOrg in canPlan -> mandantenrein
      allow update, delete: if canManage(resource.data.orgId);          // bearbeiten/archivieren

      match /recipients/{did} {
        // Owner-Muster: ownerUid == 'drv_'+driverId (= Auth-UID des Fahrers). Direkter Vergleich mit
        // request.auth.uid — nur DER laesst sich gegen where('ownerUid','==',uid) garantieren (Rules sind keine Filter).
        allow read:   if canPlan(resource.data.orgId)
                      || request.auth.uid == resource.data.ownerUid;
        allow create: if canPlan(request.resource.data.orgId)
                      && request.resource.data.ownerUid == 'drv_' + request.resource.data.driverId; // ownerUid an driverId gebunden
        allow update: if (canPlan(resource.data.orgId) && orgUnchanged())
                      || (request.auth.uid == resource.data.ownerUid && orgUnchanged() && onlyMessageStatusFields());
        allow delete: if canManage(resource.data.orgId);
      }
    }
    // Fahrer-Postfach: collectionGroup-Query ueber die EIGENEN recipient-Docs (Wildcard-Match noetig).
    // Nur das Owner-Praedikat — Firestore kann es gegen where('ownerUid','==',request.auth.uid) beweisen.
    match /{path=**}/recipients/{did} {
      allow read: if request.auth.uid == resource.data.ownerUid;
    }

    // ----- Projekte + Unterkollektionen -----
    match /projects/{pid} {
      // Org des Parent-Projekts (fuer Lesen unbeschr. Unterkollektions-Queries UND Schreibschutz)
      function projOrg() { return get(/databases/$(database)/documents/projects/$(pid)).data.orgId; }
      function canReadProj() { return inOrg(projOrg()); }
      // Neue Unterkollektions-Dokumente muessen zum Mandanten des Parent-Projekts gehoeren — verhindert,
      // dass ein Planer org-eigene Docs in ein FREMDES Projekt schreibt. get() ist pro Request/Batch gecacht
      // (Bulk-Import in EIN Projekt = ~1 Read je Batch), daher vertretbar.
      function orgIsParent() { return request.resource.data.orgId == projOrg(); }

      allow read:   if inOrg(resource.data.orgId);
      allow create: if canPlan(request.resource.data.orgId);
      allow update: if canPlan(resource.data.orgId) && orgUnchanged();
      allow delete: if canPlan(resource.data.orgId);

      match /trees/{tid} {
        allow read:   if canReadProj();
        allow create: if canPlan(request.resource.data.orgId) && orgIsParent();
        allow delete: if canPlan(resource.data.orgId);
        allow update: if (canPlan(resource.data.orgId) && orgUnchanged())
                      || (cap() == 'driver' && inOrg(resource.data.orgId) && orgUnchanged() && onlyStatusFields());
      }
      match /tours/{tid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId) && orgIsParent();
        allow update:         if (canPlan(resource.data.orgId) && orgUnchanged())
                              || (cap() == 'driver' && inOrg(resource.data.orgId) && orgUnchanged() && onlyTourStatusFields());
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /routes/{tid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId) && orgIsParent();
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /reasons/{rid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId) && orgIsParent();
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /arten/{aid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId) && orgIsParent();
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
      match /tourHistory/{hid} {
        allow read:   if canReadProj();
        allow create: if inOrg(request.resource.data.orgId) && orgIsParent() && (cap() == 'driver' || canPlan(request.resource.data.orgId));
        allow update, delete: if canPlan(resource.data.orgId);
      }
      // Auto-Planung: gespeicherte Touren-Varianten (beruehren echte Touren/Objekte nicht)
      match /planVarianten/{vid} {
        allow read:           if canReadProj();
        allow create:         if canPlan(request.resource.data.orgId) && orgIsParent();
        allow update:         if canPlan(resource.data.orgId) && orgUnchanged();
        allow delete:         if canPlan(resource.data.orgId);
      }
    }
  }
}
